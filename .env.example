# ===== TG Federal Bot - Docker 环境变量模板 =====
# 复制为 .env 后修改：cp .env.example .env

# === 必填 ===
BOT_TOKEN=你的TelegramBotToken
BOT_CREATOR=你的TelegramUserID
POSTGRES_PASSWORD=你的数据库密码(至少8位)
ADMIN_TOKEN=你的管理员API密钥(至少32位随机字符串)

# === 可选（有默认值）===
BOT_USERNAME=tg_federal_bot
POSTGRES_DB=tg_federal_bot
POSTGRES_USER=postgres
REDIS_PASSWORD=
APP_PORT=8080

# SOCKS5 代理（国内服务器使用 install.sh 时自动配置）
BOT_PROXY_ENABLED=false
BOT_PROXY_SOCKS5_HOST=127.0.0.1
BOT_PROXY_SOCKS5_PORT=7890

# 内容审核
DEEPSEEK_API_KEY=
MODERATION_PROVIDER=cloud

# 冷启动保护
SYSTEM_COLD_START=true
SYSTEM_COLD_START_DAYS=7

# JVM 内存（根据服务器内存调整）
JAVA_OPTS=-Xms512m -Xmx1024m

# Webhook（用 Nginx 反代时需要）
# WEBHOOK_URL=https://你的域名
# WEBHOOK_SECRET=自定义密钥

# 审核官
# BOT_REVIEWERS=
