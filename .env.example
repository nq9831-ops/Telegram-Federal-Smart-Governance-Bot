# ===== TG Federal Bot - Docker 环境变量模板 =====
# 复制为 .env 后修改，或直接 export 到环境中

# === 必填 ===
BOT_TOKEN=你的TelegramBotToken
BOT_CREATOR=你的TelegramUserID

# === 可选 ===
BOT_USERNAME=tg_federal_bot

# SOCKS5 代理（国内服务器使用 install.sh 时自动配置）
# 手动 Docker 部署时如需代理请取消注释
BOT_PROXY_ENABLED=false
# BOT_PROXY_HOST=127.0.0.1
# BOT_PROXY_PORT=7890

# Webhook（用 Nginx 反代时需要）
WEBHOOK_URL=https://你的域名
WEBHOOK_SECRET=自定义密钥

# 内容审核
DEEPSEEK_API_KEY=
MODERATION_PROVIDER=cloud

# 审核官
BOT_REVIEWERS=
